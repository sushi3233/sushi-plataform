# =============================================================
# BANCO DE DADOS
# No Coolify: crie um serviço PostgreSQL e copie a URL gerada
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# =============================================================
DATABASE_URL="postgresql://postgres:SENHA@localhost:5432/clubdaputaria"


# =============================================================
# CLOUDFLARE R2 (Storage de thumbnails)
# Acesse: dash.cloudflare.com → R2 → Manage R2 API tokens
# ACCOUNT_ID fica em: dash.cloudflare.com → lado direito da tela
# =============================================================
R2_ACCOUNT_ID="seu-account-id"
R2_ACCESS_KEY_ID="seu-access-key-id"
R2_SECRET_ACCESS_KEY="sua-secret-access-key"
R2_BUCKET_NAME="clubdaputaria-thumbs"

# Endpoint do R2 — substitua pelo seu ACCOUNT_ID
R2_ENDPOINT="https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com"

# URL pública das thumbnails (ative o "Public Access" no bucket R2)
NEXT_PUBLIC_R2_PUBLIC_URL="https://pub-SEU_HASH.r2.dev"


# =============================================================
# ADMIN — credenciais do painel /admin
# ADMIN_SECRET: string aleatória longa para assinar a sessão
# Gere com: openssl rand -base64 32
# =============================================================
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="sua-senha-admin"
ADMIN_NAME="Administrador"
ADMIN_SECRET="string-aleatoria-longa-minimo-32-caracteres"


# =============================================================
# URL DO SITE
# =============================================================
NEXT_PUBLIC_SITE_URL="https://seudominio.com"


# =============================================================
# OPCIONAIS
# =============================================================
NEXT_PUBLIC_TELEGRAM_BOT_URL="https://t.me/seu_bot_ou_canal"
NEXT_PUBLIC_GA_ID=""


# =============================================================
# BUILD / RUNTIME
# =============================================================
BUILD_STANDALONE="true"
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
